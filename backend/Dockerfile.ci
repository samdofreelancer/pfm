# CI-optimized Dockerfile: packages the pre-built JAR (no Maven re-download)
# Assumes: mvn clean package has already been run on the host,
# and pfm-bootstrap/target/*.jar exists.

FROM eclipse-temurin:17-jre-alpine
WORKDIR /app

# Install curl for healthcheck
RUN apk add --no-cache curl

# Copy the pre-built JAR from the host
COPY pfm-bootstrap/target/*.jar app.jar

# Expose port
EXPOSE 8080

# Run the application
ENTRYPOINT ["java", "-Duser.timezone=Asia/Ho_Chi_Minh", "-jar", "app.jar"]