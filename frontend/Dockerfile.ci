# CI-optimized Dockerfile: packages the pre-built dist (no npm install/build)
# Assumes: npm run build has already been run on the host,
# and dist/ exists.

FROM nginx:alpine
# Install curl for healthcheck
RUN apk add --no-cache curl

COPY dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]